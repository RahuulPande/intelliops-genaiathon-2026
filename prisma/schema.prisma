generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────

enum UserRole {
  admin
  viewer
  operator
}

enum ConfigType {
  credential
  endpoint
  setting
  feature_flag
}

enum SyncStatus {
  running
  success
  failed
}

enum ServiceCriticality {
  critical
  high
  medium
  low
}

// ── Models ────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String
  hashedPassword String    @map("hashed_password")
  role           UserRole  @default(viewer)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model SystemConfig {
  id          String     @id @default(uuid())
  configKey   String     @unique @map("config_key")
  configValue String?    @map("config_value")
  configType  ConfigType @map("config_type")
  category    String
  description String?
  label       String?
  isSecret    Boolean    @default(false) @map("is_secret")
  updatedBy   String?    @map("updated_by")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_configs")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  flagKey     String   @unique @map("flag_key")
  displayName String   @map("display_name")
  description String?
  category    String
  isEnabled   Boolean  @default(true) @map("is_enabled")
  allowedRoles Json    @default("[]") @map("allowed_roles")
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("feature_flags")
}

model SyncLog {
  id            String     @id @default(uuid())
  connectorId   String     @map("connector_id")
  startedAt     DateTime   @default(now()) @map("started_at")
  completedAt   DateTime?  @map("completed_at")
  status        SyncStatus @default(running)
  recordsSynced Int        @default(0) @map("records_synced")
  recordsFailed Int        @default(0) @map("records_failed")
  errorMessage  String?    @map("error_message")
  triggeredBy   String?    @map("triggered_by")

  @@index([connectorId])
  @@map("sync_logs")
}

model Service {
  id          String             @id
  name        String
  criticality ServiceCriticality @default(medium)
  team        String?
  repository  String?
  description String?

  pullRequests PullRequest[]

  @@map("services")
}

model PullRequest {
  id             String    @id
  githubId       Int       @map("github_id")
  githubUrl      String?   @map("github_url")
  title          String
  description    String?
  author         String?
  serviceId      String?   @map("service_id")
  repository     String?
  filesChanged   Int       @default(0) @map("files_changed")
  additions      Int       @default(0)
  deletions      Int       @default(0)
  changedFiles   Json?     @map("changed_files")
  diffSummary    String?   @map("diff_summary")
  commitMessages Json?     @map("commit_messages")
  riskScore      Int?      @map("risk_score")
  riskLevel      String?   @map("risk_level")
  status         String    @default("open")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  analyzedAt     DateTime? @map("analyzed_at")

  service Service? @relation(fields: [serviceId], references: [id])

  @@index([githubId])
  @@index([author])
  @@index([repository])
  @@index([serviceId])
  @@index([status])
  @@map("pull_requests")
}

model AIAnalysis {
  id             String    @id @default(uuid())
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id")
  summary        String?
  riskFactors    Json?     @map("risk_factors")
  recommendations Json?
  confidence     Float?
  model          String?
  tokensUsed     Int?      @map("tokens_used")
  latencyMs      Int?      @map("latency_ms")
  promptTemplate String?   @map("prompt_template")
  contextSources Json?     @map("context_sources")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")

  @@index([entityType])
  @@index([entityId])
  @@index([expiresAt])
  @@map("ai_analyses")
}

model WebhookEvent {
  id          Int       @id @default(autoincrement())
  source      String
  eventType   String    @map("event_type")
  action      String?
  payload     Json
  processed   String    @default("pending")
  errorMessage String?  @map("error_message")
  receivedAt  DateTime  @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")

  @@index([source])
  @@index([eventType])
  @@index([processed])
  @@map("webhook_events")
}

model RefreshTokenBlacklist {
  token     String   @id
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@map("refresh_token_blacklist")
}

// Sprint 23 — Demo Request Pipeline
model DemoRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String
  role        String
  teamSize    String   @map("team_size")
  message     String?
  status      String   @default("new") // new, contacted, qualified, converted, rejected
  source      String?  // website, linkedin, referral, event
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  contactedAt DateTime? @map("contacted_at")

  @@index([status])
  @@index([email])
  @@map("demo_requests")
}

// Sprint 23 — Contributor Tracking
model Contributor {
  id               String   @id @default(cuid())
  githubLogin      String   @unique @map("github_login")
  displayName      String?  @map("display_name")
  avatarUrl        String?  @map("avatar_url")
  firstSeenAt      DateTime @default(now()) @map("first_seen_at")
  lastActiveAt     DateTime @default(now()) @map("last_active_at")
  pullRequestCount Int      @default(0) @map("pull_request_count")

  @@index([lastActiveAt])
  @@map("contributors")
}

model ContributorSnapshot {
  id                  String   @id @default(cuid())
  snapshotDate        DateTime @map("snapshot_date")
  totalContributors   Int      @map("total_contributors")
  activeContributors  Int      @map("active_contributors")
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([snapshotDate])
  @@map("contributor_snapshots")
}

// Sprint 24 — Persistent AI Audit Trail
model AIAuditLog {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  userEmail          String?  @map("user_email")
  analysisType       String   @map("analysis_type")
  layer              String
  workspace          String
  inputSummary       String   @map("input_summary")
  outputSummary      String   @map("output_summary")
  model              String
  isSimulated        Boolean  @default(false) @map("is_simulated")
  tokenInput         Int      @default(0) @map("token_input")
  tokenOutput        Int      @default(0) @map("token_output")
  durationMs         Int      @default(0) @map("duration_ms")
  estimatedCostUsd   Float    @default(0) @map("estimated_cost_usd")
  complianceTags     String?  @map("compliance_tags")
  dataClassification String   @default("internal") @map("data_classification")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([layer, createdAt])
  @@index([analysisType, createdAt])
  @@map("ai_audit_logs")
}
